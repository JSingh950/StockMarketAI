<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MarketMind — AI Stock Predictor</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fff;--bg2:#f7f8fa;--bg3:#f0f2f5;--bg4:#e4e7ed;
  --border:#e2e5ea;--border2:#d0d4dc;
  --text:#0d1117;--text2:#4a5568;--text3:#8a94a6;
  --green:#00b37e;--green-bg:#e6f7f1;--green-light:#ccf0e3;
  --red:#e53e3e;--red-bg:#fff0f0;--red-light:#fecaca;
  --blue:#2563eb;--blue-bg:#eff6ff;
  --amber:#d97706;--amber-bg:#fffbeb;
  --shadow:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --r:10px;--rs:7px;
}
body{font-family:'DM Sans',sans-serif;background:var(--bg2);color:var(--text);min-height:100vh}
#app{max-width:980px;margin:0 auto}

/* NAV */
.topnav{background:var(--bg);border-bottom:1px solid var(--border);padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:52px;position:sticky;top:0;z-index:10}
.nav-brand{display:flex;align-items:center;gap:8px}
.nav-logo{width:28px;height:28px;background:var(--text);border-radius:6px;display:flex;align-items:center;justify-content:center}
.nav-logo svg{width:15px;height:15px}
.nav-title{font-size:15px;font-weight:600;letter-spacing:-.3px}
.live-badge{display:flex;align-items:center;gap:5px;background:var(--green-bg);border:1px solid var(--green-light);border-radius:20px;padding:3px 10px;font-size:10px;color:var(--green);font-family:'DM Mono',monospace;font-weight:500}
.live-dot{width:5px;height:5px;background:var(--green);border-radius:50%;animation:blink 1.5s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.nav-right{display:flex;gap:6px}
.nav-btn{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rs);padding:5px 12px;font-size:12px;font-weight:500;color:var(--text2);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
.nav-btn:hover{background:var(--bg3)}
.nav-btn.primary{background:var(--text);color:#fff;border-color:var(--text)}
.nav-btn.primary:hover{background:#1a2233}

/* SEARCH */
.search-zone{background:var(--bg);border-bottom:1px solid var(--border);padding:12px 20px}
.search-inner{display:flex;gap:8px;max-width:600px}
.search-wrap{flex:1;position:relative;display:flex;align-items:center}
.search-ico{position:absolute;left:11px;width:15px;height:15px;color:var(--text3);pointer-events:none}
.search-input{width:100%;background:var(--bg2);border:1.5px solid var(--border);border-radius:var(--rs);padding:9px 12px 9px 34px;font-family:'DM Mono',monospace;font-size:14px;font-weight:500;color:var(--text);letter-spacing:.5px;text-transform:uppercase;outline:none;transition:all .2s}
.search-input:focus{border-color:var(--blue);background:var(--bg);box-shadow:0 0 0 3px rgba(37,99,235,.08)}
.search-input::placeholder{color:var(--text3);text-transform:none;letter-spacing:0;font-family:'DM Sans',sans-serif;font-weight:400}
.search-btn{background:var(--text);color:#fff;border:none;border-radius:var(--rs);padding:9px 20px;font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .15s;white-space:nowrap}
.search-btn:hover{background:#1a2233}
.search-btn:active{transform:scale(.98)}
.search-btn:disabled{background:var(--bg4);color:var(--text3);cursor:not-allowed;transform:none}

/* WATCHLIST */
.watchlist{background:var(--bg);border-bottom:1px solid var(--border);padding:0 20px;display:flex;gap:0;overflow-x:auto;scrollbar-width:none}
.watchlist::-webkit-scrollbar{display:none}
.wtab{display:flex;align-items:center;gap:7px;padding:10px 14px;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;font-size:12px;color:var(--text2);transition:all .15s}
.wtab:hover{color:var(--text);background:var(--bg2)}
.wtab.active{border-bottom-color:var(--blue);color:var(--blue);font-weight:500}
.wtab-sym{font-family:'DM Mono',monospace;font-size:12px;font-weight:500}
.wtab-chg{font-size:10px;padding:1px 6px;border-radius:3px;font-family:'DM Mono',monospace;font-weight:500}
.wtab-chg.up{background:var(--green-bg);color:var(--green)}
.wtab-chg.dn{background:var(--red-bg);color:var(--red)}

.main{padding:16px 20px}

/* ERROR */
.error-banner{background:var(--red-bg);border:1px solid var(--red-light);border-radius:var(--rs);padding:10px 14px;font-size:12px;color:var(--red);margin-bottom:12px;display:none}

/* HERO */
.hero{background:var(--bg);border:1px solid var(--border);border-radius:var(--r);padding:20px 24px;margin-bottom:14px;box-shadow:var(--shadow)}
.hero-top{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px}
.hero-name{font-size:22px;font-weight:600;letter-spacing:-.4px;margin-bottom:3px}
.hero-meta{font-size:12px;color:var(--text3);display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.dot-sep{width:3px;height:3px;background:var(--border2);border-radius:50%;display:inline-block}
.hero-price{font-size:32px;font-weight:600;font-family:'DM Mono',monospace;letter-spacing:-1px;text-align:right}
.hero-change{display:flex;align-items:center;gap:6px;justify-content:flex-end;margin-top:4px}
.chg-pill{font-size:13px;font-weight:500;padding:3px 10px;border-radius:20px;font-family:'DM Mono',monospace}
.chg-pill.up{background:var(--green-bg);color:var(--green)}
.chg-pill.dn{background:var(--red-bg);color:var(--red)}
.chg-period{font-size:11px;color:var(--text3)}
.quick-stats{display:grid;grid-template-columns:repeat(6,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--rs);overflow:hidden}
.qs{background:var(--bg);padding:9px 12px}
.qs-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px}
.qs-val{font-size:12px;font-weight:500;font-family:'DM Mono',monospace;color:var(--text)}

/* GRID */
.layout-grid{display:grid;grid-template-columns:1fr 296px;gap:14px;margin-bottom:14px}

/* CARDS */
.card{background:var(--bg);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden}
.card-hdr{display:flex;align-items:center;justify-content:space-between;padding:13px 16px 0}
.card-title{font-size:11px;font-weight:500;color:var(--text2);text-transform:uppercase;letter-spacing:.5px}
.tf-grp{display:flex;gap:2px;background:var(--bg2);border-radius:6px;padding:2px}
.tf-btn{background:transparent;border:none;border-radius:4px;padding:3px 9px;font-size:11px;font-weight:500;font-family:'DM Mono',monospace;color:var(--text3);cursor:pointer;transition:all .15s}
.tf-btn.active{background:var(--bg);color:var(--text);box-shadow:0 1px 2px rgba(0,0,0,.08)}
.tf-btn:hover:not(.active){color:var(--text2)}
.chart-legend{display:flex;gap:14px;padding:8px 16px 0;flex-wrap:wrap}
.leg-item{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text3)}
.leg-line{width:18px;height:2px;border-radius:1px}
.chart-wrap{position:relative;width:100%;height:240px;padding:8px 16px 12px}

/* SIDEBAR */
.sidebar{display:flex;flex-direction:column;gap:14px}
.sig-body{padding:14px}
.sig-row{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.sig-badge{font-size:22px;font-weight:600;padding:6px 18px;border-radius:var(--rs);font-family:'DM Mono',monospace}
.sig-badge.buy{background:var(--green-bg);color:var(--green)}
.sig-badge.sell{background:var(--red-bg);color:var(--red)}
.sig-badge.hold{background:var(--amber-bg);color:var(--amber)}
.score-wrap{flex:1}
.score-lbl{font-size:10px;color:var(--text3);margin-bottom:4px}
.score-track{height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.score-fill{height:100%;border-radius:3px;transition:width 1s ease}
.score-num{font-size:11px;font-family:'DM Mono',monospace;color:var(--text2);margin-top:3px}
.conf-row{display:flex;justify-content:space-between;padding:8px 0 0;border-top:1px solid var(--border)}
.conf-lbl{font-size:11px;color:var(--text3)}
.conf-val{font-size:12px;font-family:'DM Mono',monospace;font-weight:500}
.prob-body{padding:14px}
.prob-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.prob-row:last-child{margin-bottom:0}
.prob-lbl{font-size:11px;width:52px;flex-shrink:0}
.prob-track{flex:1;height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.prob-fill{height:100%;border-radius:3px;transition:width 1.2s cubic-bezier(.4,0,.2,1)}
.prob-pct{font-size:11px;font-family:'DM Mono',monospace;color:var(--text3);width:28px;text-align:right}
.ind-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border)}
.ind-cell{background:var(--bg);padding:10px 12px}
.ind-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px}
.ind-val{font-size:15px;font-weight:500;font-family:'DM Mono',monospace}
.ind-tag{font-size:10px;padding:2px 7px;border-radius:3px;display:inline-block;margin-top:3px;font-weight:500}
.it-bull{background:var(--green-bg);color:var(--green)}
.it-bear{background:var(--red-bg);color:var(--red)}
.it-neut{background:var(--bg3);color:var(--text3)}
.it-hot{background:var(--amber-bg);color:var(--amber)}

/* PATTERNS */
.pat-body{padding:4px 16px 14px}
.pat-row{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border)}
.pat-row:last-child{border-bottom:none}
.pat-ico{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.pat-ico.bull{background:var(--green-bg)}
.pat-ico.bear{background:var(--red-bg)}
.pat-ico.neut{background:var(--bg3)}
.pat-info{flex:1}
.pat-name{font-size:12px;font-weight:500}
.pat-str{font-size:10px;color:var(--text3)}
.pat-sig{font-size:10px;font-weight:500;padding:2px 8px;border-radius:3px}
.ps-bull{background:var(--green-bg);color:var(--green)}
.ps-bear{background:var(--red-bg);color:var(--red)}
.ps-neut{background:var(--bg3);color:var(--text3)}
.pat-count{font-size:11px;color:var(--text3);font-family:'DM Mono',monospace}

/* SR */
.sr-body{padding:0 16px 14px}
.sr-row{display:flex;align-items:center;justify-content:space-between;padding:6px 10px;border-radius:var(--rs);margin-bottom:4px}
.sr-row:last-child{margin-bottom:0}
.sr-row.resist{background:var(--red-bg);border-left:3px solid var(--red)}
.sr-row.cur{background:var(--blue-bg);border-left:3px solid var(--blue)}
.sr-row.supp{background:var(--green-bg);border-left:3px solid var(--green)}
.sr-type{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:1px}
.sr-price{font-family:'DM Mono',monospace;font-weight:500;font-size:13px}
.sr-dist{font-size:11px;font-family:'DM Mono',monospace}

/* NEWS */
.news-row{display:flex;gap:10px;padding:10px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s;text-decoration:none;color:inherit}
.news-row:last-child{border-bottom:none}
.news-row:hover{background:var(--bg2)}
.news-headline{font-size:12px;font-weight:500;line-height:1.4;margin-bottom:3px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.news-meta{font-size:10px;color:var(--text3)}

/* AI */
.ai-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden;margin-bottom:14px}
.ai-hdr{display:flex;align-items:center;gap:8px;padding:13px 16px;border-bottom:1px solid var(--border);background:#f8faff}
.ai-dot{width:8px;height:8px;background:var(--blue);border-radius:50%;animation:blink 2s infinite}
.ai-title{font-size:11px;font-weight:600;color:var(--blue);text-transform:uppercase;letter-spacing:.5px}
.ai-model{font-size:10px;color:var(--text3);margin-left:auto;font-family:'DM Mono',monospace}
.ai-body{padding:16px;font-size:13px;line-height:1.8;color:var(--text2)}
.ai-body.loading{color:var(--text3)}
.sk{background:var(--bg3);border-radius:4px;height:13px;margin-bottom:8px;animation:shimmer 1.5s infinite;background-size:200% 100%}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0;background:linear-gradient(90deg,var(--bg3) 25%,var(--bg4) 50%,var(--bg3) 75%)}}

/* PEER */
.peer-row{display:flex;align-items:center;justify-content:space-between;padding:7px 12px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s}
.peer-row:last-child{border-bottom:none}
.peer-row:hover{background:var(--bg2)}
.peer-sym{font-family:'DM Mono',monospace;font-size:12px;font-weight:500}
.peer-chg{font-size:11px;font-family:'DM Mono',monospace}

/* EMPTY */
.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 20px;text-align:center}
.empty-ico{font-size:40px;margin-bottom:14px;opacity:.25}
.empty-title{font-size:17px;font-weight:500;color:var(--text2);margin-bottom:8px}
.empty-sub{font-size:13px;color:var(--text3);max-width:340px;line-height:1.65}

/* SPINNER */
.spin{display:inline-block;width:14px;height:14px;border:2px solid var(--border2);border-top-color:var(--blue);border-radius:50%;animation:spin .6s linear infinite;vertical-align:middle}
@keyframes spin{to{transform:rotate(360deg)}}

.disclaimer{text-align:center;padding:6px 0 20px;font-size:10px;color:var(--text3)}



@media(max-width:700px){
  .layout-grid{grid-template-columns:1fr}
  .quick-stats{grid-template-columns:repeat(3,1fr)}
  .quick-stats .qs:nth-child(n+4){display:none}
  .hero-price{font-size:26px}
  .hero-name{font-size:18px}
}
</style>
</head>
<body>



<div id="app">

  <div class="topnav">
    <div class="nav-brand">
      <div class="nav-logo">
        <svg viewBox="0 0 16 16" fill="none"><polyline points="1,12 5,7 8,10 12,4 15,6" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <span class="nav-title">MarketMind</span>
    </div>
    <div class="live-badge"><div class="live-dot"></div>Finnhub Live</div>
    <div class="nav-right">
      <button class="nav-btn primary" onclick="runAnalysis()">↻ Refresh</button>
    </div>
  </div>

  <div class="search-zone">
    <div class="search-inner">
      <div class="search-wrap">
        <svg class="search-ico" viewBox="0 0 16 16" fill="none"><circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 10l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <input class="search-input" id="searchInput" type="text" placeholder="Search ticker — AAPL, NVDA, TSLA, BTC-USD…" maxlength="10"/>
      </div>
      <button class="search-btn" id="analyzeBtn" onclick="runAnalysis()">Analyze</button>
    </div>
  </div>

  <div class="watchlist" id="watchlist"></div>

  <div class="main">
    <div class="error-banner" id="errorBanner"></div>

    <div class="empty" id="emptyState">
      <div class="empty-ico">📈</div>
      <div class="empty-title">Search any stock to begin</div>
      <div class="empty-sub">Enter a ticker symbol above. Live prices, candles, fundamentals and news are pulled directly from Finnhub in real time.</div>
    </div>

    <div id="dashboard" style="display:none">

      <div class="hero">
        <div class="hero-top">
          <div>
            <div class="hero-name" id="heroName">—</div>
            <div class="hero-meta">
              <span id="heroTicker" style="font-family:'DM Mono',monospace;font-weight:500"></span>
              <span class="dot-sep"></span><span id="heroExchange"></span>
              <span class="dot-sep"></span><span id="heroSector" style="color:var(--text3)"></span>
            </div>
          </div>
          <div>
            <div class="hero-price" id="heroPrice">—</div>
            <div class="hero-change">
              <span class="chg-pill" id="heroChgPill">—</span>
              <span class="chg-period">Today</span>
            </div>
            <div style="font-size:10px;color:var(--text3);text-align:right;margin-top:3px" id="heroTimestamp"></div>
          </div>
        </div>
        <div class="quick-stats">
          <div class="qs"><div class="qs-lbl">Open</div><div class="qs-val" id="qs-open">—</div></div>
          <div class="qs"><div class="qs-lbl">High</div><div class="qs-val" id="qs-high">—</div></div>
          <div class="qs"><div class="qs-lbl">Low</div><div class="qs-val" id="qs-low">—</div></div>
          <div class="qs"><div class="qs-lbl">Mkt Cap</div><div class="qs-val" id="qs-mcap">—</div></div>
          <div class="qs"><div class="qs-lbl">P/E Ratio</div><div class="qs-val" id="qs-pe">—</div></div>
          <div class="qs"><div class="qs-lbl">52W High</div><div class="qs-val" id="qs-52h">—</div></div>
        </div>
      </div>

      <div class="layout-grid">
        <div style="display:flex;flex-direction:column;gap:14px">

          <div class="card">
            <div class="card-hdr">
              <span class="card-title" id="chartTitle">Price History</span>
              <div class="tf-grp">
                <button class="tf-btn active" id="tf-1W" onclick="setTF('1W')">1W</button>
                <button class="tf-btn" id="tf-1M" onclick="setTF('1M')">1M</button>
                <button class="tf-btn" id="tf-3M" onclick="setTF('3M')">3M</button>
                <button class="tf-btn" id="tf-1Y" onclick="setTF('1Y')">1Y</button>
              </div>
            </div>
            <div class="chart-legend">
              <div class="leg-item"><div class="leg-line" style="background:#2563eb"></div>Price</div>
              <div class="leg-item"><div class="leg-line" style="background:#f59e0b"></div>SMA 20</div>
              <div class="leg-item"><div class="leg-line" style="background:#8b5cf6"></div>SMA 50</div>
              <div class="leg-item"><div class="leg-line" style="background:#00b37e;border-top:2px dashed #00b37e;height:0;width:18px"></div><span style="margin-left:5px">Median Forecast</span></div>
              <div class="leg-item"><div style="width:18px;height:8px;background:rgba(37,99,235,0.12);border-radius:2px"></div>Confidence Range</div>
            </div>
            <div class="chart-wrap"><canvas id="priceChart"></canvas></div>
          </div>

          <div class="card">
            <div class="card-hdr" style="padding-bottom:8px">
              <span class="card-title">Detected Chart Patterns</span>
              <span class="pat-count" id="patCount"></span>
            </div>
            <div class="pat-body" id="patList"></div>
          </div>

          <div class="card">
            <div class="card-hdr" style="padding-bottom:10px"><span class="card-title">Support &amp; Resistance</span></div>
            <div class="sr-body" id="srLevels"></div>
          </div>

          <div class="card">
            <div class="card-hdr" style="padding-bottom:10px"><span class="card-title">Latest News</span></div>
            <div id="newsList"></div>
          </div>

        </div>

        <div class="sidebar">

          <div class="card">
            <div class="card-hdr" style="padding-bottom:10px"><span class="card-title">AI Signal</span></div>
            <div class="sig-body">
              <div class="sig-row">
                <div class="sig-badge" id="sigBadge">—</div>
                <div class="score-wrap">
                  <div class="score-lbl">Pattern Score</div>
                  <div class="score-track"><div class="score-fill" id="scoreFill" style="width:0%"></div></div>
                  <div class="score-num" id="scoreNum">—</div>
                </div>
              </div>
              <div class="conf-row">
                <span class="conf-lbl">Model confidence</span>
                <span class="conf-val" id="confVal">—</span>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="card-hdr" style="padding-bottom:10px"><span class="card-title">30-Day Probability</span></div>
            <div class="prob-body">
              <div class="prob-row"><div class="prob-lbl" style="color:var(--green)">Bullish</div><div class="prob-track"><div class="prob-fill" id="pb-bull" style="width:0%;background:var(--green)"></div></div><div class="prob-pct" id="pp-bull">—</div></div>
              <div class="prob-row"><div class="prob-lbl" style="color:var(--text3)">Neutral</div><div class="prob-track"><div class="prob-fill" id="pb-neut" style="width:0%;background:var(--bg4)"></div></div><div class="prob-pct" id="pp-neut">—</div></div>
              <div class="prob-row"><div class="prob-lbl" style="color:var(--red)">Bearish</div><div class="prob-track"><div class="prob-fill" id="pb-bear" style="width:0%;background:var(--red)"></div></div><div class="prob-pct" id="pp-bear">—</div></div>
            </div>
          </div>

          <div class="card">
