// ── Finnhub ───────────────────────────────────────────────────────
async function fh(path) {
  const r = await fetch(`https://finnhub.io/api/v1${path}&token=${API_KEY}`);
  if (!r.ok) throw new Error('Finnhub ' + r.status);
  return r.json();
}
function tfParams(tf) {
  const now = Math.floor(Date.now()/1000);
  const map = { '1W':{res:'60',days:7}, '1M':{res:'D',days:30}, '3M':{res:'D',days:90}, '1Y':{res:'W',days:365} };
  const c = map[tf]; return { resolution:c.res, from:now-c.days*86400, to:now };
}
function fmtMcap(v) {
  if (!v) return '—';
  if (v>=1e12) return '$'+(v/1e12).toFixed(2)+'T';
  if (v>=1e9)  return '$'+(v/1e9).toFixed(1)+'B';
  return '$'+(v/1e6).toFixed(0)+'M';
}
function timeAgo(ts) {
  const s=Math.floor(Date.now()/1000)-ts;
  if(s<3600) return Math.floor(s/60)+'m ago';
  if(s<86400) return Math.floor(s/3600)+'h ago';
  return Math.floor(s/86400)+'d ago';
}

// ── Math helpers ──────────────────────────────────────────────────
function smaArr(arr,n){return arr.map((_,i)=>i<n-1?null:arr.slice(i-n+1,i+1).reduce((a,b)=>a+b,0)/n)}
function emaArr(arr,n){const k=2/(n+1),e=[];arr.forEach((v,i)=>e.push(i===0?v:v*k+e[i-1]*(1-k)));return e}
function calcRSI(arr,n=14){
  const ch=arr.slice(1).map((v,i)=>v-arr[i]);
  let g=0,l=0;
  for(let i=0;i<n;i++){if(ch[i]>0)g+=ch[i];else l-=ch[i]}
  let ag=g/n,al=l/n;
  const r=[null];
  for(let i=n;i<ch.length;i++){
    const gv=ch[i]>0?ch[i]:0,lv=ch[i]<0?-ch[i]:0;
    ag=(ag*(n-1)+gv)/n; al=(al*(n-1)+lv)/n;
    r.push(al===0?100:100-(100/(1+ag/al)));
  }
  return r;
}
function calcMACD(arr){
  const e12=emaArr(arr,12),e26=emaArr(arr,26);
  const ml=e12.map((v,i)=>v-e26[i]),sig=emaArr(ml,9);
  return {ml, sig, hist:ml.map((v,i)=>v-sig[i])};
}
function calcBB(arr,n=20){
  const s=smaArr(arr,n);
  return s.map((m,i)=>{
    if(!m) return {upper:null,mid:null,lower:null,bw:null};
    const sd=Math.sqrt(arr.slice(i-n+1,i+1).reduce((a,v)=>a+Math.pow(v-m,2),0)/n);
    return {upper:m+2*sd, mid:m, lower:m-2*sd, bw:(4*sd)/m};
  });
}
function calcVol(arr,n=20){
  const logs=arr.slice(1).map((v,i)=>Math.log(v/arr[i]));
  const s=logs.slice(-n),m=s.reduce((a,b)=>a+b,0)/n;
  return Math.sqrt(s.reduce((a,v)=>a+Math.pow(v-m,2),0)/n)*Math.sqrt(252)*100;
}
function calcStoch(closes,highs,lows,n=14){
  return closes.map((_,i)=>{
    if(i<n-1) return null;
    const hh=Math.max(...highs.slice(i-n+1,i+1));
    const ll=Math.min(...lows.slice(i-n+1,i+1));
    return hh===ll ? 50 : (closes[i]-ll)/(hh-ll)*100;
  });
}
function calcATR(closes,highs,lows,n=14){
  const tr=closes.map((_,i)=>{
    if(i===0) return highs[i]-lows[i];
    return Math.max(highs[i]-lows[i], Math.abs(highs[i]-closes[i-1]), Math.abs(lows[i]-closes[i-1]));
  });
  return smaArr(tr,n);
}

// ── Feature extraction: compute all indicators at bar i ───────────
function extractFeatures(closes, highs, lows, volumes, i, rsiArr, macdData, bbData, sma20, sma50, sma200, stochArr, atrArr) {
  const c = closes[i];
  if (!c || i < 60) return null;

  const rsi = rsiArr[i] || 50;
  const macdHist = macdData.hist[i] || 0;
  const macdHistPrev = macdData.hist[i-3] || 0;
  const bb = bbData[i];
  const bw = bb?.bw || 0.05;
  const bbPct = bb?.upper && bb?.lower ? (c - bb.lower) / (bb.upper - bb.lower) : 0.5; // 0=at lower, 1=at upper
  const s20 = sma20[i], s50 = sma50[i], s200 = sma200[i];
  const stoch = stochArr[i] || 50;
  const atr = atrArr[i] || 1;

  // Price momentum features
  const ret5  = i>=5  ? (c/closes[i-5]-1)*100  : 0;
  const ret10 = i>=10 ? (c/closes[i-10]-1)*100 : 0;
  const ret20 = i>=20 ? (c/closes[i-20]-1)*100 : 0;

  // Volume momentum (volume vs 20-day avg)
  const volAvg = volumes.slice(Math.max(0,i-20),i).reduce((a,b)=>a+b,0)/20 || 1;
  const volRatio = (volumes[i]||1) / volAvg;

  // Trend quality (R² of 20-bar linear regression)
  const recent = closes.slice(i-19, i+1);
  const xm = 9.5, ym = recent.reduce((a,b)=>a+b,0)/20;
  let num=0,den=0; recent.forEach((y,x)=>{num+=(x-xm)*(y-ym);den+=(x-xm)**2});
  const slope = den>0 ? num/den : 0;
  const fitted = recent.map((_,x)=>ym+slope*(x-xm));
  const ssTot = recent.reduce((a,v)=>a+Math.pow(v-ym,2),0);
  const ssRes = recent.reduce((a,v,ii)=>a+Math.pow(v-fitted[ii],2),0);
  const r2 = ssTot>0 ? Math.max(0,1-ssRes/ssTot) : 0;
  const trendSlope = ym>0 ? (slope/ym)*100 : 0;

  // Distance from key MAs (%)
  const distSma20  = s20  ? (c/s20-1)*100  : 0;
  const distSma50  = s50  ? (c/s50-1)*100  : 0;
  const distSma200 = s200 ? (c/s200-1)*100 : 0;

  // MA alignment (bullish = 20>50>200)
  const maAlignment = (s20&&s50&&s200) ? (s20>s50?1:0) + (s50>s200?1:0) - 1 : 0; // -1 to +1

  // Volatility (annualized)
  const logs = closes.slice(Math.max(0,i-20),i).map((v,ii,a)=>ii>0?Math.log(v/a[ii-1]):0).filter(Boolean);
  const localVol = logs.length>1 ? Math.sqrt(logs.reduce((a,v)=>a+v*v,0)/logs.length)*Math.sqrt(252)*100 : 20;

  // ATR % of price (normalized volatility)
  const atrPct = atr ? (atr/c)*100 : 1;

  // Candlestick body size
  const high = highs[i], low = lows[i];
  const bodySize = Math.abs(c - (closes[i-1]||c)) / (high-low||1);

  return [
    rsi/100,                        // 0: RSI normalized
    Math.tanh(macdHist/c*100),      // 1: MACD hist normalized
    Math.tanh((macdHist-macdHistPrev)/c*100), // 2: MACD acceleration
    bbPct,                          // 3: Bollinger %B
    Math.min(bw*10, 2)/2,           // 4: Bollinger bandwidth (normalized)
    stoch/100,                      // 5: Stochastic
    Math.tanh(ret5/5),              // 6: 5-day return
    Math.tanh(ret10/8),             // 7: 10-day return
    Math.tanh(ret20/12),            // 8: 20-day return
    Math.min(volRatio/3,1),         // 9: Volume ratio
    r2,                             // 10: Trend R²
    Math.tanh(trendSlope),          // 11: Trend slope
    Math.tanh(distSma20/5),         // 12: Dist from SMA20
    Math.tanh(distSma50/8),         // 13: Dist from SMA50
    Math.tanh(distSma200/15),       // 14: Dist from SMA200
    (maAlignment+1)/2,              // 15: MA alignment 0-1
    Math.min(localVol/80,1),        // 16: Local volatility
    Math.min(atrPct/3,1),           // 17: ATR%
    bodySize,                       // 18: Candle body size
  ];
}

// ── Labels: what actually happened 20 bars later ──────────────────
// Returns: 1 (bullish: >2%), -1 (bearish: <-2%), 0 (neutral)
function labelOutcome(closes, i, horizon=20) {
  if (i + horizon >= closes.length) return null;
  const ret = (closes[i+horizon] / closes[i] - 1) * 100;
  if (ret > 2)  return 1;
  if (ret < -2) return -1;
  return 0;
}

// ── Gradient Boosted Trees (XGBoost-style) in pure JS ─────────────
// Simplified but real: uses decision tree stumps as weak learners
class GradientBoostedModel {
  constructor(nTrees=80, lr=0.12, maxDepth=4, subsample=0.8) {
    this.nTrees = nTrees;
    this.lr = lr;
    this.maxDepth = maxDepth;
    this.subsample = subsample;
    this.trees = [];   // for bull class
    this.treesB = [];  // for bear class
    this.F0 = 0;
    this.F0b = 0;
    this.featureImportance = new Array(19).fill(0);
    this.trained = false;
    this.trainAccuracy = 0;
    this.nSamples = 0;
  }

  // Build a regression tree to fit residuals
  buildTree(X, residuals, depth, indices) {
    const n = indices.length;
    if (n < 6 || depth === 0) {
      const mean = indices.reduce((a,i)=>a+residuals[i],0)/n;
      return { leaf: true, value: mean };
    }
    const nFeatures = X[0].length;
    let bestGain = -Infinity, bestFeat = -1, bestThresh = 0, bestLeft = [], bestRight = [];

    // Try random subset of features (like Random Forest)
    const nTry = Math.max(3, Math.floor(Math.sqrt(nFeatures)));
    const featIdx = [...Array(nFeatures).keys()].sort(()=>Math.random()-.5).slice(0,nTry);

    for (const f of featIdx) {
      const vals = indices.map(i=>X[i][f]).sort((a,b)=>a-b);
      // Try a few split thresholds
      for (let t = 1; t < Math.min(vals.length, 8); t++) {
        const thresh = (vals[Math.floor(vals.length*t/8)] + vals[Math.floor(vals.length*(t+1)/8)]) / 2;
        const left = indices.filter(i=>X[i][f]<=thresh);
        const right = indices.filter(i=>X[i][f]>thresh);
        if (left.length < 3 || right.length < 3) continue;
        const meanL = left.reduce((a,i)=>a+residuals[i],0)/left.length;
        const meanR = right.reduce((a,i)=>a+residuals[i],0)/right.length;
        const gain = left.length*meanL*meanL + right.length*meanR*meanR;
        if (gain > bestGain) { bestGain=gain; bestFeat=f; bestThresh=thresh; bestLeft=left; bestRight=right; }
      }
    }
    if (bestFeat === -1) {
      return { leaf:true, value: indices.reduce((a,i)=>a+residuals[i],0)/n };
    }
    this.featureImportance[bestFeat] += bestGain * n;
    return {
      leaf: false, feat: bestFeat, thresh: bestThresh,
      left:  this.buildTree(X, residuals, depth-1, bestLeft),
      right: this.buildTree(X, residuals, depth-1, bestRight),
    };
  }

  predictTree(tree, x) {
    if (tree.leaf) return tree.value;
    return x[tree.feat] <= tree.thresh ? this.predictTree(tree.left, x) : this.predictTree(tree.right, x);
  }

  sigmoid(x) { return 1/(1+Math.exp(-Math.max(-10,Math.min(10,x)))); }

  train(X, labels) {
    const n = X.length;
    this.nSamples = n;
    this.trained = false;
    if (n < 30) return;

    // Binary labels: bull vs rest, bear vs rest
    const yBull = labels.map(l => l===1?1:0);
    const yBear = labels.map(l => l===-1?1:0);

    const bullRate = yBull.reduce((a,b)=>a+b,0)/n;
    const bearRate = yBear.reduce((a,b)=>a+b,0)/n;
    this.F0  = Math.log((bullRate+1e-6)/(1-bullRate+1e-6));
    this.F0b = Math.log((bearRate+1e-6)/(1-bearRate+1e-6));

    let Fbull = new Array(n).fill(this.F0);
    let Fbear = new Array(n).fill(this.F0b);
    this.trees = []; this.treesB = [];

    for (let t = 0; t < this.nTrees; t++) {
      // Subsampling
      const idx = [...Array(n).keys()].filter(()=>Math.random()<this.subsample);

      // Bull gradient
      const resBull = idx.map(i => yBull[i] - this.sigmoid(Fbull[i]));
      const treeBull = this.buildTree(X, resBull, this.maxDepth, idx);
      this.trees.push(treeBull);
      idx.forEach(i => { Fbull[i] += this.lr * this.predictTree(treeBull, X[i]); });

      // Bear gradient
      const resBear = idx.map(i => yBear[i] - this.sigmoid(Fbear[i]));
      const treeBear = this.buildTree(X, resBear, this.maxDepth, idx);
      this.treesB.push(treeBear);
      idx.forEach(i => { Fbear[i] += this.lr * this.predictTree(treeBear, X[i]); });
    }

    // Normalize feature importance
    const totalImp = this.featureImportance.reduce((a,b)=>a+b,0)||1;
    this.featureImportance = this.featureImportance.map(v=>v/totalImp);

    // Training accuracy on last 20% (out-of-time validation)
    const valStart = Math.floor(n*0.8);
    let correct = 0;
    for (let i = valStart; i < n; i++) {
      const pred = this.predictProba(X[i]);
      const predLabel = pred[0]>pred[2] && pred[0]>pred[1] ? 1 : pred[2]>pred[1] ? -1 : 0;
      if (predLabel === labels[i]) correct++;
    }
    this.trainAccuracy = Math.round(correct/(n-valStart)*100);
    this.trained = true;
  }

  predictProba(x) {
    // Returns [pBull, pNeutral, pBear]
    let scoreBull = this.F0, scoreBear = this.F0b;
    for (const t of this.trees)  scoreBull += this.lr * this.predictTree(t, x);
    for (const t of this.treesB) scoreBear += this.lr * this.predictTree(t, x);
    const pBull = this.sigmoid(scoreBull);
    const pBear = this.sigmoid(scoreBear);
    // Normalize to sum to 1
    const total = pBull + pBear + (1-pBull+1-pBear)/2;
    const nb = Math.max(0.01, pBull);
    const sb = Math.max(0.01, pBear);
    const nn = Math.max(0.01, 1 - nb - sb);
    const s = nb+sb+nn;
    return [nb/s, nn/s, sb/s]; // [pBull, pNeutral, pBear]
  }
}

// ── TRAIN model on 5 years of this stock's own history ───────────
async function trainModel(ticker) {
  if (MODEL_CACHE[ticker]) return MODEL_CACHE[ticker]; // use cached

  setStatus(`Training model on ${ticker} history…`, 'Fetching 5 years of daily candles from Finnhub');

  const now = Math.floor(Date.now()/1000);
  const fiveYearsAgo = now - 5*365*86400;

  let candles;
  try {
    candles = await fh(`/stock/candle?symbol=${ticker}&resolution=D&from=${fiveYearsAgo}&to=${now}`);
  } catch(e) {
    setStatus('');
    return null;
  }

  if (candles.s !== 'ok' || !candles.c || candles.c.length < 100) {
    setStatus('');
    return null;
  }

  const closes  = candles.c;
  const highs   = candles.h;
  const lows    = candles.l;
  const volumes = candles.v;
  const n = closes.length;

  setStatus(`Training on ${ticker}…`, `Computing indicators across ${n} trading days`);

  // Pre-compute all indicators across full history
  const rsiArr   = calcRSI(closes);
  const macdData = calcMACD(closes);
  const bbData   = calcBB(closes);
  const sma20    = smaArr(closes, 20);
  const sma50    = smaArr(closes, 50);
  const sma200   = smaArr(closes, 200);
  const stochArr = calcStoch(closes, highs, lows);
  const atrArr   = calcATR(closes, highs, lows);

  // Build training dataset
  const X = [], y = [];
  for (let i = 60; i < n - 20; i++) {
    const features = extractFeatures(closes, highs, lows, volumes, i, rsiArr, macdData, bbData, sma20, sma50, sma200, stochArr, atrArr);
    const label = labelOutcome(closes, i, 20);
    if (features && label !== null) {
      X.push(features);
      y.push(label);
    }
  }

  setStatus(`Training on ${ticker}…`, `Fitting Gradient Boosted Trees on ${X.length} labeled samples`);

  // Allow UI to update before heavy computation
  await new Promise(r => setTimeout(r, 30));

  const model = new GradientBoostedModel(80, 0.12, 4, 0.8);
  model.train(X, y);

  // Also store the full history for self-backtesting display
  const result = {
    model,
    closes, highs, lows, volumes,
    rsiArr, macdData, bbData, sma20, sma50, sma200, stochArr, atrArr,
    n,
    ticker,
    trainedAt: Date.now(),
    accuracy: model.trainAccuracy,
    nSamples: X.length,
    // Compute per-class base rates for display
    bullRate: Math.round(y.filter(v=>v===1).length/y.length*100),
    bearRate: Math.round(y.filter(v=>v===-1).length/y.length*100),
  };

  MODEL_CACHE[ticker] = result;
  setStatus('');
  return result;
}

// ── Run inference on current bar ──────────────────────────────────
function predict(trainedModel, recentCloses, recentHighs, recentLows, recentVolumes) {
  const { model, rsiArr, macdData, bbData, sma20, sma50, sma200, stochArr, atrArr, closes, highs, lows, volumes } = trainedModel;

  // Stitch recent (live) data onto training data for fresh indicators
  const allC = [...closes, ...recentCloses.slice(1)];
  const allH = [...highs,  ...recentHighs.slice(1)];
  const allL = [...lows,   ...recentLows.slice(1)];
  const allV = [...volumes, ...recentVolumes.slice(1)];
  const N = allC.length;

  const freshRSI   = calcRSI(allC);
  const freshMACD  = calcMACD(allC);
  const freshBB    = calcBB(allC);
  const freshS20   = smaArr(allC, 20);
  const freshS50   = smaArr(allC, 50);
  const freshS200  = smaArr(allC, 200);
  const freshStoch = calcStoch(allC, allH, allL);
  const freshATR   = calcATR(allC, allH, allL);

  const idx = N - 1;
  const features = extractFeatures(allC, allH, allL, allV, idx, freshRSI, freshMACD, freshBB, freshS20, freshS50, freshS200, freshStoch, freshATR);
  if (!features) return null;

  const [pBull, pNeut, pBear] = model.predictProba(features);
  const score = Math.round((pBull - pBear) * 100);

  return {
    pBull: Math.round(pBull*100),
    pNeut: Math.round(pNeut*100),
    pBear: Math.round(pBear*100),
    score,
    signal: score > 10 ? 'BUY' : score < -10 ? 'SELL' : 'HOLD',
    conf: Math.min(88, Math.round(50 + Math.abs(score) * 0.4 + trainedModel.accuracy * 0.2)),
    features,
    featureNames: ['RSI','MACD Hist','MACD Accel','BB %B','BB Width','Stochastic','Ret 5d','Ret 10d','Ret 20d','Vol Ratio','Trend R²','Trend Slope','Dist SMA20','Dist SMA50','Dist SMA200','MA Align','Volatility','ATR%','Body Size'],
    featureImportance: trainedModel.model.featureImportance,
    rawProbas: [pBull, pNeut, pBear],
  };
}

// ── Self-backtest: run model on recent history to show real accuracy ─
function runBacktest(trainedModel) {
  const { model, closes, highs, lows, volumes, rsiArr, macdData, bbData, sma20, sma50, sma200, stochArr, atrArr, n } = trainedModel;
  const results = [];
  // Last 90 labeled bars
  const start = Math.max(60, n - 110);
  for (let i = start; i < n - 20; i++) {
    const features = extractFeatures(closes, highs, lows, volumes, i, rsiArr, macdData, bbData, sma20, sma50, sma200, stochArr, atrArr);
    const actual = labelOutcome(closes, i, 20);
    if (!features || actual === null) continue;
    const [pBull,,pBear] = model.predictProba(features);
    const predicted = (pBull-pBear) > 0.1 ? 1 : (pBear-pBull) > 0.1 ? -1 : 0;
    results.push({ predicted, actual, correct: predicted === actual, date: i });
  }
  const total = results.length;
  const correct = results.filter(r=>r.correct).length;
  const bullCalls  = results.filter(r=>r.predicted===1);
  const bearCalls  = results.filter(r=>r.predicted===-1);
  return {
    total, correct,
    accuracy: total>0 ? Math.round(correct/total*100) : 0,
    bullPrecision: bullCalls.length>0  ? Math.round(bullCalls.filter(r=>r.correct).length/bullCalls.length*100)  : 0,
    bearPrecision: bearCalls.length>0  ? Math.round(bearCalls.filter(r=>r.correct).length/bearCalls.length*100)  : 0,
  };
}

// ── Pattern detection (still used for display + context) ──────────
function detectTrend(p,w=20){
  const s=p.slice(-w),n=s.length,xm=(n-1)/2,ym=s.reduce((a,b)=>a+b,0)/n;
  let num=0,den=0;s.forEach((y,x)=>{num+=(x-xm)*(y-ym);den+=(x-xm)**2});
  const sl=(num/den/ym)*100;
  const fitted=s.map((_,x)=>ym+(num/den)*(x-xm));
  const ssTot=s.reduce((a,v)=>a+Math.pow(v-ym,2),0);
  const ssRes=s.reduce((a,v,i)=>a+Math.pow(v-fitted[i],2),0);
  const r2=Math.max(0,ssTot>0?1-ssRes/ssTot:0);
  const quality=r2>0.7?'High':r2>0.4?'Medium':'Low';
  if(sl>0.3)return{type:'Uptrend Channel',signal:'bullish',strength:quality,icon:'↑'};
  if(sl<-0.3)return{type:'Downtrend Channel',signal:'bearish',strength:quality,icon:'↓'};
  return{type:'Consolidation Zone',signal:'neutral',strength:'Low',icon:'→'};
}
function detectHS(p){
  const r=p.slice(-50),pks=[];
  for(let i=2;i<r.length-2;i++)if(r[i]>r[i-1]&&r[i]>r[i-2]&&r[i]>r[i+1]&&r[i]>r[i+2])pks.push({i,v:r[i]});
  if(pks.length>=3){const[a,h,b]=pks.slice(-3);if(h.v>a.v&&h.v>b.v&&Math.abs(a.v-b.v)/h.v<0.08&&Math.min(h.i-a.i,b.i-h.i)>=3)return{type:'Head & Shoulders',signal:'bearish',strength:'High',icon:'⊥'}}
  return null;
}
function detectInvHS(p){
  const r=p.slice(-50),tr=[];
  for(let i=2;i<r.length-2;i++)if(r[i]<r[i-1]&&r[i]<r[i-2]&&r[i]<r[i+1]&&r[i]<r[i+2])tr.push({i,v:r[i]});
  if(tr.length>=3){const[a,h,b]=tr.slice(-3);if(h.v<a.v&&h.v<b.v&&Math.abs(a.v-b.v)/a.v<0.08&&Math.min(h.i-a.i,b.i-h.i)>=3)return{type:'Inv. Head & Shoulders',signal:'bullish',strength:'High',icon:'⊤'}}
  return null;
}
function detectDT(p){
  const r=p.slice(-40),pks=[];
  for(let i=2;i<r.length-2;i++)if(r[i]>r[i-1]&&r[i]>r[i+1])pks.push({i,v:r[i]});
  if(pks.length>=2){const[a,b]=pks.slice(-2);const pd=Math.abs(a.v-b.v)/a.v,gap=b.i-a.i;if(pd<0.03&&gap>=5&&gap<=30)return{type:'Double Top',signal:'bearish',strength:pd<0.015?'High':'Medium',icon:'⌒'}}
  return null;
}
function detectDB(p){
  const r=p.slice(-40),tr=[];
  for(let i=2;i<r.length-2;i++)if(r[i]<r[i-1]&&r[i]<r[i+1])tr.push({i,v:r[i]});
  if(tr.length>=2){const[a,b]=tr.slice(-2);const pd=Math.abs(a.v-b.v)/a.v,gap=b.i-a.i;if(pd<0.03&&gap>=5&&gap<=30)return{type:'Double Bottom',signal:'bullish',strength:pd<0.015?'High':'Medium',icon:'⌣'}}
  return null;
}
function detectGC(s50,s200,idx){
  if(!s50[idx]||!s200[idx]||idx<5)return null;
  for(let k=1;k<=5;k++){
    if(!s50[idx-k]||!s200[idx-k])continue;
    if(s50[idx]>s200[idx]&&s50[idx-k]<s200[idx-k])return{type:'Golden Cross (50/200)',signal:'bullish',strength:'High',icon:'✦'};
    if(s50[idx]<s200[idx]&&s50[idx-k]>s200[idx-k])return{type:'Death Cross (50/200)',signal:'bearish',strength:'High',icon:'✦'};
  }
  return{type:s50[idx]>s200[idx]?'Above 200-day SMA':'Below 200-day SMA',signal:s50[idx]>s200[idx]?'bullish':'bearish',strength:'Low',icon:'—'};
}
function detectBBSq(arr){
  const bb=calcBB(arr);
  const bws=bb.map(b=>b.bw).filter(Boolean);
  if(bws.length<10)return null;
  const avg=bws.slice(-30).reduce((a,b)=>a+b,0)/Math.min(30,bws.length);
  if(bws[bws.length-1]<avg*.7)return{type:'Bollinger Squeeze',signal:'neutral',strength:'Medium',icon:'⇔'};
  return null;
}
function findSR(p){
  const levs=[],w=5;
  for(let i=w;i<p.length-w;i++){
    const sl=p.slice(i-w,i+w+1),mn=Math.min(...sl),mx=Math.max(...sl);
    if(p[i]===mn)levs.push({price:p[i],type:'support',strength:0});
    if(p[i]===mx)levs.push({price:p[i],type:'resistance',strength:0});
  }
  const cl=[],thr=p[p.length-1]*.02;
  levs.forEach(l=>{
    const ex=cl.find(c=>Math.abs(c.price-l.price)<thr&&c.type===l.type);
    if(ex){ex.price=(ex.price+l.price)/2;ex.strength++}else cl.push({...l});
  });
  return cl.sort((a,b)=>b.strength-a.strength).slice(0,8);
}

// ── Monte Carlo forecast with ML drift ───────────────────────────
function renderChart(closes, timestamps, pred, annualVol) {
  const s20=smaArr(closes,Math.min(20,closes.length));
  const s50=smaArr(closes,Math.min(50,closes.length));
  const predDays=20, last=closes[closes.length-1];
  const dailyDrift = (pred.pBull - pred.pBear) / 100 * 0.003;
  const dailyVol = (Math.max(annualVol,8) / 100) / Math.sqrt(252);

  // Monte Carlo: 300 paths
  const N=300, paths=[];
  for(let sim=0;sim<N;sim++){
    const path=[last];
    for(let d=1;d<=predDays;d++){
      // Box-Muller normal
      const u1=Math.random(),u2=Math.random();
      const z=Math.sqrt(-2*Math.log(u1+1e-10))*Math.cos(2*Math.PI*u2);
      path.push(Math.max(path[d-1]*0.5, path[d-1]*(1+dailyDrift+dailyVol*z)));
    }
    paths.push(path);
  }
  const pct=(paths,q)=>[...Array(predDays+1).keys()].map(d=>{
    const v=paths.map(p=>p[d]).sort((a,b)=>a-b);
    return parseFloat(v[Math.floor(N*q)].toFixed(2));
  });
  const median=pct(paths,.5),u75=pct(paths,.75),l25=pct(paths,.25),u90=pct(paths,.90),l10=pct(paths,.10);

  const labels=timestamps.map(ts=>new Date(ts*1000).toLocaleDateString('en-US',{month:'short',day:'numeric'}));
  for(let i=1;i<=predDays;i++){const d=new Date();d.setDate(d.getDate()+i);labels.push(d.toLocaleDateString('en-US',{month:'short',day:'numeric'}))}
  const gap=Array(closes.length-1).fill(null);
  const hD=[...closes,...Array(predDays).fill(null)];

  if(chart)chart.destroy();
  const ctx=document.getElementById('priceChart').getContext('2d');
  chart=new Chart(ctx,{type:'line',data:{labels,datasets:[
    {label:'90ci_u',data:[...gap,last,...u90.slice(1)],borderColor:'transparent',pointRadius:0,fill:false,tension:.3},
    {label:'90ci_l',data:[...gap,last,...l10.slice(1)],borderColor:'transparent',pointRadius:0,fill:'-1',backgroundColor:'rgba(37,99,235,0.04)',tension:.3},
    {label:'75ci_u',data:[...gap,last,...u75.slice(1)],borderColor:'transparent',pointRadius:0,fill:false,tension:.3},
    {label:'25ci_l',data:[...gap,last,...l25.slice(1)],borderColor:'transparent',pointRadius:0,fill:'-1',backgroundColor:'rgba(37,99,235,0.09)',tension:.3},
    {label:'Median Forecast',data:[...gap,last,...median.slice(1)],borderColor:'#00b37e',borderWidth:2,borderDash:[5,3],pointRadius:0,fill:false,tension:.3},
    {label:'SMA 20',data:[...s20,...Array(predDays).fill(null)],borderColor:'#f59e0b',borderWidth:1,pointRadius:0,tension:.3,borderDash:[3,2]},
    {label:'SMA 50',data:[...s50,...Array(predDays).fill(null)],borderColor:'#8b5cf6',borderWidth:1,pointRadius:0,tension:.3,borderDash:[4,2]},
    {label:'Price',data:hD,borderColor:'#2563eb',borderWidth:2,pointRadius:0,tension:.3,fill:{target:'origin',above:'rgba(37,99,235,0.03)'}},
  ]},options:{responsive:true,maintainAspectRatio:false,interaction:{intersect:false,mode:'index'},
    plugins:{legend:{display:false},tooltip:{
      backgroundColor:'#fff',borderColor:'#e2e5ea',borderWidth:1,
      titleColor:'#8a94a6',bodyColor:'#0d1117',
      titleFont:{family:'DM Mono',size:10},bodyFont:{family:'DM Mono',size:11},padding:10,
      filter:item=>['Price','Median Forecast','75ci_u','25ci_l'].includes(item.dataset.label),
      callbacks:{label:ctx=>{
        const l=ctx.dataset.label;
        if(l==='Price') return ' Price: $'+ctx.parsed.y.toFixed(2);
        if(l==='Median Forecast') return ' Forecast (median): $'+ctx.parsed.y.toFixed(2);
        if(l==='75ci_u') return ' Bull case (75th pct): $'+ctx.parsed.y.toFixed(2);
        if(l==='25ci_l') return ' Bear case (25th pct): $'+ctx.parsed.y.toFixed(2);
        return null;
      }}
    }},
    scales:{
      x:{ticks:{color:'#8a94a6',font:{family:'DM Mono',size:9},maxTicksLimit:8,maxRotation:0},grid:{color:'#f0f2f5'},border:{color:'#e2e5ea'}},
      y:{position:'right',ticks:{color:'#8a94a6',font:{family:'DM Mono',size:9},callback:v=>'$'+v.toFixed(0)},grid:{color:'#f7f8fa'},border:{color:'#e2e5ea'}}
    }
  }});
}

