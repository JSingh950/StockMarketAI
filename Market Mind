              <div style="font-size:11px;font-family:'DM Mono',monospace;color:var(--text2);width:120px;flex-shrink:0">${f.name}</div>
              <div style="flex:1;height:5px;background:var(--bg3);border-radius:3px;overflow:hidden"><div style="height:100%;width:${Math.round(f.imp*100*5)}%;background:var(--blue);border-radius:3px;max-width:100%"></div></div>
              <div style="font-size:10px;font-family:'DM Mono',monospace;color:var(--text3);width:32px;text-align:right">${(f.imp*100).toFixed(1)}%</div>
            </div>`).join('')}
        </div>`;
    } else {
      accCard.style.display = 'none';
    }

    // ── Indicators ────────────────────────────────────────────────
    document.getElementById('ind-rsi').textContent=rsiVal;
    document.getElementById('ind-rsi').style.color=rsiVal>70?'var(--amber)':rsiVal<30?'var(--blue)':rsiVal>55?'var(--green)':'var(--text)';
    const rsiTag=rsiVal>70?'Overbought':rsiVal<30?'Oversold':rsiVal>55?'Bullish':'Neutral';
    document.getElementById('ind-rsi-tag').textContent=rsiTag;
    document.getElementById('ind-rsi-tag').className='ind-tag '+(rsiVal>70?'it-hot':rsiVal<30?'it-bull':rsiVal>55?'it-bull':'it-neut');
    document.getElementById('ind-macd').textContent=(macdVal>=0?'+':'')+macdVal.toFixed(2);
    document.getElementById('ind-macd').style.color=macdVal>=0?'var(--green)':'var(--red)';
    document.getElementById('ind-macd-tag').textContent=macdVal>=0?'Bullish':'Bearish';
    document.getElementById('ind-macd-tag').className='ind-tag '+(macdVal>=0?'it-bull':'it-bear');
    document.getElementById('ind-sma20').textContent=sma20l?'$'+sma20l.toFixed(0):'—';
    document.getElementById('ind-sma20').style.color=price>sma20l?'var(--green)':'var(--red)';
    document.getElementById('ind-sma20-tag').textContent=price>sma20l?'Above':'Below';
    document.getElementById('ind-sma20-tag').className='ind-tag '+(price>sma20l?'it-bull':'it-bear');
    document.getElementById('ind-vol').textContent=vol.toFixed(1)+'%';
    const volTag=vol>40?'High':vol>25?'Elevated':'Normal';
    document.getElementById('ind-vol-tag').textContent=volTag;
    document.getElementById('ind-vol-tag').className='ind-tag '+(vol>40?'it-hot':vol>25?'it-hot':'it-neut');

    // ── News ──────────────────────────────────────────────────────
    const topNews=(news||[]).slice(0,5);
    document.getElementById('newsList').innerHTML=topNews.length===0
      ?'<div style="padding:12px 16px;font-size:12px;color:var(--text3)">No recent news found.</div>'
      :topNews.map(n=>`<a class="news-row" href="${n.url}" target="_blank" rel="noopener"><div><div class="news-headline">${n.headline}</div><div class="news-meta">${n.source} · ${timeAgo(n.datetime)}</div></div></a>`).join('');

    // ── Peers ─────────────────────────────────────────────────────
    const topPeers=(peers||[]).filter(p=>p!==ticker).slice(0,5);
    document.getElementById('peerList').innerHTML=topPeers.length===0
      ?'<div style="padding:10px 12px;font-size:12px;color:var(--text3)">No peers found.</div>'
      :topPeers.map(sym=>`<div class="peer-row" onclick="document.getElementById('searchInput').value='${sym}';runAnalysis()"><span class="peer-sym">${sym}</span><span class="peer-chg" id="peer-${sym}" style="color:var(--text3)">…</span></div>`).join('');
    topPeers.forEach(sym=>fh(`/quote?symbol=${sym}`).then(q=>{const el=document.getElementById('peer-'+sym);if(el){const p=q.dp||0;el.textContent=(p>=0?'+':'')+p.toFixed(2)+'%';el.style.color=p>=0?'var(--green)':'var(--red)'}}).catch(()=>{}));

    // ── Chart ─────────────────────────────────────────────────────
    if(closes.length>0) renderChart(closes,timestamps,pred,vol);
    else document.querySelector('.chart-wrap').innerHTML='<div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:12px;color:var(--text3)">No chart data — try 1M, 3M or 1Y</div>';

    // ── AI analysis ───────────────────────────────────────────────
    const topR=resistances[0]?'$'+resistances[0].price.toFixed(2):'N/A';
    const topS=supports[0]?'$'+supports[0].price.toFixed(2):'N/A';
    const rangePos=h52&&l52?((price-l52)/(h52-l52)*100).toFixed(0)+'%':'—';
    const patSummary=pats.map(p=>`${p.type} (${p.signal})`).join(', ')||'None detected';
    const backtestStr=backtest?`Backtest accuracy on ${ticker}: ${backtest.accuracy}% overall, ${backtest.bullPrecision}% BUY precision, ${backtest.bearPrecision}% SELL precision over last ${backtest.total} windows.`:'Model not available.';
    const topFeatStr=pred.featureImportance&&pred.featureNames?pred.featureImportance.map((v,i)=>({n:pred.featureNames[i],v})).sort((a,b)=>b.v-a.v).slice(0,3).map(f=>`${f.n} (${(f.v*100).toFixed(0)}%)`).join(', '):'—';

    const resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:`You are a quantitative analyst reviewing output from a Gradient Boosted Trees model trained on 5 years of ${ticker} (${profile.name||ticker}) daily candle data.\n\nLIVE PRICE: $${price.toFixed(2)} | Change: ${chgPct.toFixed(2)}% | 52W: $${l52}–$${h52} (${rangePos})\nFundamentals: P/E ${pe||'—'}, Beta ${beta}, MCap ${mcap}, Sector: ${profile.finnhubIndustry||'—'}\n\nML MODEL OUTPUT:\n${backtestStr}\nML Signal: ${pred.signal} | 20-day probabilities: ${pred.pBull}% bullish / ${pred.pNeut}% neutral / ${pred.pBear}% bearish\nModel confidence: ${pred.conf}%\nTop predictive features driving this prediction: ${topFeatStr}\n\nTECHNICAL CONTEXT:\nRSI(14): ${rsiVal} (${rsiTag}) | MACD: ${macdVal.toFixed(2)} | Vol: ${vol.toFixed(1)}%\nDetected patterns: ${patSummary}\nKey levels — Support: ${topS} | Resistance: ${topR}\n\nWrite 4 precise sentences: (1) Interpret what the ML model's top features are signaling right now for ${ticker} specifically, (2) How the live technicals (RSI, MACD, patterns) corroborate or conflict with the model output, (3) The significance of the key price levels given the current position, (4) A 20-day price target with bull/bear range derived from the ${pred.pBull}%/${pred.pBear}% probability split. Cite real $ prices. No disclaimers.`}]})});
    const aiData=await resp.json();
    document.getElementById('aiOutput').className='ai-body';
    document.getElementById('aiOutput').textContent=aiData.content?.find(b=>b.type==='text')?.text||'Analysis unavailable.';

  } catch(err) {
    console.error(err);
    setStatus('');
    const eb=document.getElementById('errorBanner');
    eb.style.display='block';
    eb.textContent='⚠ '+err.message;
    document.getElementById('aiOutput').className='ai-body';
    document.getElementById('aiOutput').textContent='Failed: '+err.message;
  }

  btn.disabled=false; btn.textContent='Analyze';
}

document.getElementById('searchInput').addEventListener('keydown',e=>{if(e.key==='Enter')runAnalysis()});
function setTF(tf){currentTF=tf;document.querySelectorAll('.tf-btn').forEach(b=>b.classList.remove('active'));document.getElementById('tf-'+tf).classList.add('active');if(currentData)runAnalysis()}

// Init
buildWatchlist('');
</script>
</body>
</html>
